# Copy this file to .env and fill in your values

# Port the server listens on (hosting platforms set this automatically)
PORT=3001

# Set to "production" when deploying
NODE_ENV=production

# Your deployed app's public URL (used for CORS)
# e.g. https://mahjong-matchmaker.up.railway.app
CLIENT_URL=https://yourdomain.com

# Optional: custom path for the SQLite database file
# Defaults to server/mahjong.db
# On Railway/Render, point this to a persistent volume mount
# DB_PATH=/data/mahjong.db
